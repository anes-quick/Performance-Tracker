# Copy to .env and fill in. Do not commit .env.

# Path to Google service account JSON (for Sheets read/write).
# Create in Google Cloud Console → IAM → Service Accounts, then share your spreadsheet with the service account email.
GOOGLE_APPLICATION_CREDENTIALS=path/to/your-service-account.json

# YouTube Data API v3 key (for public channel/video data).
# Enable "YouTube Data API v3" in Google Cloud Console → APIs, then create an API key.
YOUTUBE_API_KEY=your-youtube-api-key
